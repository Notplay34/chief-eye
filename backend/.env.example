# Среда: development | test | production
APP_ENV=development

# Подключение к PostgreSQL (async)
DATABASE_URL=postgresql+asyncpg://eye_user:eye_pass@localhost:5432/eye_w

# Секрет для JWT.
# В production обязателен. В development/test при отсутствии будет сгенерирован временный секрет на время процесса.
JWT_SECRET=

# Разрешённые CORS origin через запятую.
# В production задайте явно, без "*".
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Стартовый суперпользователь создаётся только если заданы все три поля ниже.
SUPERUSER_LOGIN=
SUPERUSER_PASSWORD=
SUPERUSER_NAME=
